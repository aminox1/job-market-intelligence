# =============================================
# Job Market Intelligence — Configuration
# =============================================
# Copier ce fichier en .env et remplir les valeurs

# --- Remotive API (100% GRATUIT, pas de clé requise) ---
# Aucune configuration nécessaire !

# --- Adzuna API (GRATUIT - inscription sur https://developer.adzuna.com) ---
# Optionnel : active plus d'offres d'emploi (France, UK, US...)
ADZUNA_APP_ID=your_app_id_here
ADZUNA_APP_KEY=your_app_key_here
ADZUNA_COUNTRY=fr

# --- Scheduler (mise à jour automatique des données) ---
# Intervalle en heures (défaut: 6h)
REFRESH_INTERVAL_HOURS=6

# --- App Config ---
APP_NAME=Job Market Intelligence
APP_VERSION=1.0.0
DEBUG=false
